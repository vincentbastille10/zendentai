# ─────────────────────────────────────────────
#  ZenDentAI — Variables d'environnement
#
# ── Together AI (recommandé) ──────────────────
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
#
# ─────────────────────────────────────────────
#
# Copiez ce fichier en .env.local pour le développement.
# Sur Vercel, ajoutez ces variables dans Settings > Environment Variables.
#
# Sans LLM_API_KEY, l'app fonctionne avec les scripts locaux (data/meditations.ts).
# Aucun crash si les variables sont absentes.

# Fournisseur LLM (openai | anthropic | mistral | togetherai | …)
LLM_PROVIDER=openai

# Clé API du fournisseur
LLM_API_KEY=

# Modèle à utiliser
LLM_MODEL=gpt-4o-mini

# Base URL (optionnel — utile pour proxies ou APIs compatibles OpenAI)
LLM_BASE_URL=https://api.openai.com/v1
